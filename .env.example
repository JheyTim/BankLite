# Application
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000

# Auth Service
AUTH_SERVICE_PORT=3001

# User Service
USER_SERVICE_PORT=3002

# Account Service
ACCOUNT_SERVICE_PORT=3003

# Wallet Service
WALLET_SERVICE_PORT=3004

# Ledger Service
LEDGER_SERVICE_PORT=3005

# Transaction Service
TRANSACTION_SERVICE_PORT=3006

# Notification Service
NOTIFICATION_SERVICE_PORT=3007

# Audit Service
AUDIT_SERVICE_PORT=3008

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=banklite
POSTGRES_PASSWORD=banklite_password
POSTGRES_DB=banklite

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://banklite:banklite_password@localhost:5672

# Floci local AWS-compatible endpoint
FLOCI_ENDPOINT=http://localhost:4566
FLOCI_REGION=us-east-1
FLOCI_ACCESS_KEY_ID=test
FLOCI_SECRET_ACCESS_KEY=test