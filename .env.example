# Application environment.
NODE_ENV=development

# Default app port for API Gateway.
API_GATEWAY_PORT=3000

# Service ports.
AUTH_SERVICE_PORT=3001
USER_PROFILE_SERVICE_PORT=3002
KYC_SERVICE_PORT=3003
ACCOUNT_SERVICE_PORT=3004
LEDGER_SERVICE_PORT=3005
TRANSFER_SERVICE_PORT=3006
BILL_PAYMENT_SERVICE_PORT=3007
FRAUD_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
FILE_SERVICE_PORT=3010
AUDIT_LOG_SERVICE_PORT=3011

# JWT configuration.
JWT_SECRET=change-me-in-local-dev
JWT_EXPIRES_IN=15m

# PostgreSQL local Docker configuration.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=banklite
POSTGRES_PASSWORD=banklite
POSTGRES_DB=banklite

# Redis local Docker configuration.
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ local Docker configuration.
RABBITMQ_URL=amqp://banklite:banklite@localhost:5672

# Floci local AWS-compatible endpoint.
AWS_REGION=ap-southeast-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Local S3-style buckets.
AWS_KYC_DOCUMENTS_BUCKET=banklite-kyc-documents
AWS_SUPPORT_DOCUMENTS_BUCKET=banklite-support-documents
AWS_STATEMENTS_BUCKET=banklite-statements