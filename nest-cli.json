      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "ledger-service": {
      "type": "application",
      "root": "apps/ledger-service",
      "entryFile": "main",
      "sourceRoot": "apps/ledger-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ledger-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
