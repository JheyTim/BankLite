{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/banklite/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/banklite/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/banklite",
  "projects": {
    "account-service": {
      "type": "application",
      "root": "apps/account-service",
      "entryFile": "main",
      "sourceRoot": "apps/account-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/account-service/tsconfig.app.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "audit-service": {
      "type": "application",
      "root": "apps/audit-service",
      "entryFile": "main",
      "sourceRoot": "apps/audit-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/audit-service/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "banklite": {
      "type": "application",
      "root": "apps/banklite",
      "entryFile": "main",
      "sourceRoot": "apps/banklite/src",
      "compilerOptions": {
